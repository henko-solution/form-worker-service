# Henko Form Worker Service - Environment Variables
# Copy this file to .env and update the values

# Application Configuration
DEBUG=True
APP_NAME=Henko Form Worker Service
AWS_REGION=us-east-1

# SQS Configuration
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/form-dispatch-events-qa
SQS_MAX_NUMBER_OF_MESSAGES=10
SQS_WAIT_TIME_SECONDS=20

# External Services URLs
FORM_SERVICE_URL=http://localhost:8002
EMPLOYEE_SERVICE_URL=http://localhost:8001

# Cognito Configuration
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret  # Optional, only if client has secret
COGNITO_SYSTEM_USERNAME=system-user@henkosolution.com
COGNITO_SYSTEM_PASSWORD=your-system-user-password

# Internal API Authentication (deprecated - use Cognito instead)
INTERNAL_API_KEY=your-internal-api-key-here

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Batch Configuration
ASSIGNMENT_BATCH_SIZE=100

# Logging
LOG_LEVEL=INFO

# Candidate forms configuration
# Comma-separated list of candidate assessment form names in Form Service
CANDIDATE_FORM_NAMES=Huvantia Measure,Integridad,Valores Huvantia,Habilidades Cognitivas,Motivaciones,Liderazgo,Personalidad
